{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/health",           "dest": "/api/index.js" },
    { "src": "/login",            "dest": "/api/index.js" },
    { "src": "/register",         "dest": "/api/index.js" },
    { "src": "/denuncia",         "dest": "/api/index.js" },
    { "src": "/ocorrencias(.*)",  "dest": "/api/index.js" },
    { "src": "/usuarios(.*)",     "dest": "/api/index.js" }
  ]
}
