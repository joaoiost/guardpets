# Copie este arquivo para .env e preencha com seus valores reais
# Nunca versione o arquivo .env com dados reais

PORT=3000

# Supabase — cole a connection string do painel:
# Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres

# JWT — troque por uma string longa e aleatória
JWT_SECRET=troque_isso_por_uma_chave_segura_em_producao
